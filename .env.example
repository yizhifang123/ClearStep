# Set ANY ONE of these to enable live AI analysis of CUSTOM synthetic patients.
# Without a key, the three built-in demo patients still work fully (cached text +
# live model signal).
#
# ANTHROPIC_API_KEY=sk-ant-...
# OPENAI_API_KEY=sk-...
# GEMINI_API_KEY=AIza...
#
# Optional overrides:
# MINDBRIDGE_PROVIDER=gemini        # force a provider if multiple keys are set
# MINDBRIDGE_MODEL=gemini-2.0-flash # override the default model for that provider
